import re
import hashlib

# Task 1: Text processing
def word_count(text: str) -> dict[str, int]:
    """
    Повертає словник {слово: кількість_вхождень}.
    """
    words = re.findall(r'\b\w+\b', text.lower())
    counts: dict[str, int] = {}
    for w in words:
        counts[w] = counts.get(w, 0) + 1
    return counts

def frequent_words(counts: dict[str, int], threshold: int = 3) -> list[str]:
    """
    Повертає список слів, що зустрічаються більше threshold разів.
    """
    return [word for word, cnt in counts.items() if cnt > threshold]


# Task 2: Inventory management
inventory: dict[str, int] = {}

def update_inventory(product: str, qty: int) -> dict[str, int]:
    inventory[product] = inventory.get(product, 0) + qty
    if inventory[product] <= 0:
        del inventory[product]
    return inventory

def low_stock(threshold: int = 5) -> list[str]:
    return [p for p, q in inventory.items() if q < threshold]


# Task 3: Sales statistics
def total_revenue(sales: list[dict[str, int | float]]) -> tuple[dict[str, float], list[str]]:
    rev: dict[str, float] = {}
    for s in sales:
        prod = s["продукт"]
        rev[prod] = rev.get(prod, 0.0) + s["кількість"] * s["ціна"]
    high = [p for p, r in rev.items() if r > 1000]
    return rev, high


# Task 4: Task management system
tasks: dict[str, str] = {}

def add_task(name: str, status: str) -> None:
    tasks[name] = status

def remove_task(name: str) -> None:
    tasks.pop(name, None)

def update_task(name: str, status: str) -> None:
    if name in tasks:
        tasks[name] = status

def pending_tasks() -> list[str]:
    return [n for n, s in tasks.items() if s == "очікує"]


# Task 5: User authentication
users: dict[str, dict[str, str]] = {}

def hash_password(password: str) -> str:
    return hashlib.md5(password.encode('utf-8')).hexdigest()

def add_user(login: str, password: str, full_name: str = "Зайдліч Данііил Максимович") -> None:
    users[login] = {
        "password_hash": hash_password(password),
        "full_name": full_name
    }

def authenticate(login: str) -> bool:
    pwd = input("Пароль: ")
    return (
        login in users
        and users[login]["password_hash"] == hash_password(pwd)
    )


