import re

def word_count(text: str) -> dict:
    """
    Возвращает словарь {слово: количество_вхождений}.
    """
    words = re.findall(r'\b\w+\b', text.lower())
    counts = {}
    for w in words:
        counts[w] = counts.get(w, 0) + 1
    return counts

def frequent_words(counts: dict, threshold: int = 3) -> list:
    """
    Возвращает список слов, встречающихся более threshold раз.
    """
    return [word for word, cnt in counts.items() if cnt > threshold]

